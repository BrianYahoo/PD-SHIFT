# 当前 dataset 标识，供代码识别 HCP 配置。
DATASET_TYPE="hcp"
# HCP 原始数据根目录。
RAW_ROOT="/data/bryang/project/CNS/data/HCP/raw"
# HCP workspace 根目录。
WORKSPACE_ROOT="/data/bryang/project/CNS/data/HCP/workspace"
# HCP 的原始数据导入模式，表示直接使用现成 NIfTI。
DATASET_IMPORT_MODE="hcp_nifti"
# HCP 当前不限制 subject 编号范围；留空表示扫描 raw 目录下全部 subject。
DATASET_SUBJECT_KEY_MIN=
# HCP 当前不限制 subject 编号范围；留空表示扫描 raw 目录下全部 subject。
DATASET_SUBJECT_KEY_MAX=
# HCP 是否在 phase0 对 T1 做重采样；当前关闭。
INIT_T1_RESAMPLE_ENABLE=0
# 若启用 T1 重采样，目标体素分辨率是多少 mm；HCP 当前保留 1 mm。
INIT_T1_RESAMPLE_VOXEL_SIZE=1
# HCP 是否导入 T2；当前默认开启。
INIT_T2_ENABLE=1
# HCP 查找 T2 目录时使用的候选目录名列表。
INIT_T2_HCP_DIR_CANDIDATES="T2w_SPC1;T2w_SPC2"
# HCP 在候选目录内匹配 T2 文件时使用的文件名模式。
INIT_T2_HCP_FILE_PATTERNS="*T2w*.nii.gz"
# HCP 在缺少 JSON TR 时允许使用的默认 TR。
DEFAULT_FUNC_TR=0.72
# HCP 是否强制要求 fMRI TR 必须来自 JSON；当前允许 fallback。
FUNC_REQUIRE_JSON_TR=0
# HCP 的默认总读出时间兜底值。
DEFAULT_TOTAL_READOUT_TIME=0.05
# HCP phase1 默认脑提取方法。
PHASE1_BRAIN_EXTRACT_METHOD="bet"
# HCP 是否强制开启 FreeSurfer `-hires`；当前关闭，由输入分辨率自动决定。
PHASE1_SURFER_HIRES=0
# HCP 是否启用 T2 到 T1 的刚体配准；当前开启。
PHASE1_T2_COREG_ENABLE=1
# HCP 是否在 Surfer 中使用 T2；当前开启。
PHASE1_T2_SURFER_ENABLE=1
# HCP 是否在 Step3 中启用 T1+T2 双通道配准；当前开启。
PHASE1_T2_MULTICHANNEL_REG_ENABLE=1
# HCP 是否在 Step3 中启用皮层下 mask 约束；当前关闭。
PHASE1_SUBCORTICAL_MASK_ENABLE=0
# HCP 是否启用 phase1 的 T1/T2/myelin 区域值与 CIFTI 输出；当前默认开启。
PHASE1_TISSUE_PROFILE_ENABLE=1
# HCP 是否生成 32k fsLR 的 T1/T2/myelin CIFTI 与皮层 surf 图；当前默认开启。
PHASE1_TISSUE_PROFILE_CIFTI_ENABLE=1
# HCP 是否在 Step3 中启用 Affine 阶段；当前开启。
PHASE1_REG_AFFINE_ENABLE=1
# HCP 是否强制禁用 FreeSurfer v8 新默认流程；当前关闭。
PHASE1_FREESURFER_NO_V8=0
# HCP 是否检查并防止误用 v8 默认 synthstrip/synthseg/synthmorph 路径；当前关闭。
PHASE1_FREESURFER_V8_GUARD=0
# HCP 传给 FreeSurfer `CortexLabel` 的额外参数；当前为空。
PHASE1_FREESURFER_CORTEX_LABEL_ARGS=""
# HCP 传给 FastSurfer label-cortex 的额外参数；当前为空。
PHASE1_FASTSURFER_LABEL_CORTEX_ARGS=""
# HCP FastSurfer 的体素大小策略；`min` 表示尊重原始输入。
PHASE1_FASTSURFER_VOX_SIZE="min"
# HCP FastSurfer 是否使用 CUDA；当前关闭。
FASTSURFER_USE_CUDA=0
# HCP FastSurfer 是否自动分配 GPU；当前关闭。
FASTSURFER_CUDA_AUTO_ASSIGN=0
# 若启用自动分配，GPU 选择策略是什么；HCP 当前虽未启用，但默认仍保留轮转模式。
FASTSURFER_CUDA_SELECTION="round_robin"
# 自动 GPU 选择时最多参与挑选的 GPU 数量。
FASTSURFER_CUDA_MAX_SELECTED_DEVICES=5
