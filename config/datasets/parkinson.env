# 当前 dataset 标识，供代码识别 Parkinson 配置。
DATASET_TYPE="parkinson"
# Parkinson 原始数据根目录。
RAW_ROOT="/data/bryang/project/CNS/data/Parkinson/raw"
# Parkinson workspace 根目录。
WORKSPACE_ROOT="/data/bryang/project/CNS/data/Parkinson/workspace"
# Parkinson 的原始数据导入模式，表示从 DICOM 转换导入。
DATASET_IMPORT_MODE="parkinson_dicom"
# Parkinson 是否在 phase0 对 T1 做重采样；当前开启。
INIT_T1_RESAMPLE_ENABLE=1
# Parkinson T1 重采样目标分辨率，单位 mm。
INIT_T1_RESAMPLE_VOXEL_SIZE=0.7
# Parkinson 是否导入 T2；当前关闭，仅使用 T1。
INIT_T2_ENABLE=0
# Parkinson 从原始目录中匹配 T2 序列时使用的目录名模式列表，越靠前优先级越高。
INIT_T2_SOURCE_PATTERNS="t2_fse_tra*;t2*tra*;t2_space*;t2_cube*;t2_3d*;t2_*"
# Parkinson fMRI 是否必须从 dcm2niix 的 BIDS JSON 中读取 TR；当前强制要求。
FUNC_REQUIRE_JSON_TR=1
# Parkinson 的默认总读出时间兜底值。
DEFAULT_TOTAL_READOUT_TIME=0.05
# Parkinson phase1 默认脑提取方法，当前使用 FreeSurfer SynthStrip。
PHASE1_BRAIN_EXTRACT_METHOD="synthstrip"
# Parkinson 是否显式要求 FreeSurfer 进入 hires 路径；当前开启。
PHASE1_SURFER_HIRES=1
# Parkinson 是否启用 T2 到 T1 的刚体配准；当前关闭，仅使用 T1。
PHASE1_T2_COREG_ENABLE=0
# Parkinson 是否在 Surfer 中使用 T2；当前关闭，仅使用 T1。
PHASE1_T2_SURFER_ENABLE=0
# Parkinson 是否在 Step3 中启用 T1+T2 双通道配准；当前关闭，仅使用 T1。
PHASE1_T2_MULTICHANNEL_REG_ENABLE=0
# Parkinson 是否在 Step3 中启用皮层下 mask 约束；当前开启。
PHASE1_SUBCORTICAL_MASK_ENABLE=1
# Parkinson 是否启用 phase1 的 T1/T2/myelin 区域值与 CIFTI 输出；当前关闭，仅使用 T1。
PHASE1_TISSUE_PROFILE_ENABLE=0
# Parkinson 是否生成 32k fsLR 的 T1/T2/myelin CIFTI 与皮层 surf 图；当前关闭，仅使用 T1。
PHASE1_TISSUE_PROFILE_CIFTI_ENABLE=0
# Parkinson 是否在 Step3 中启用 Affine 阶段；当前关闭，以保护深部结构局部锁定。
PHASE1_REG_AFFINE_ENABLE=0
# Parkinson 是否禁用 FreeSurfer v8 新默认流程；当前开启。
PHASE1_FREESURFER_NO_V8=1
# Parkinson 是否检查并防止误用 FreeSurfer v8 默认 synth 路径；当前开启。
PHASE1_FREESURFER_V8_GUARD=1
# Parkinson 传给 FreeSurfer `CortexLabel` 的附加参数，用于减少 cortex label 修补。
PHASE1_FREESURFER_CORTEX_LABEL_ARGS="--no-fix-ga"
# Parkinson 传给 FastSurfer label-cortex 的附加参数，用于减少 cortex label 修补并保留 hip/amyg 处理。
PHASE1_FASTSURFER_LABEL_CORTEX_ARGS="--no-fix-ga --hip-amyg"
# Parkinson FastSurfer 固定使用的体素分辨率，单位 mm。
PHASE1_FASTSURFER_VOX_SIZE=0.7
# Parkinson FastSurfer 是否使用 CUDA；当前开启。
FASTSURFER_USE_CUDA=1
# Parkinson FastSurfer 是否自动分配 GPU；当前开启。
FASTSURFER_CUDA_AUTO_ASSIGN=1
# Parkinson 允许参与 FastSurfer 自动 GPU 分配的显卡列表。
FASTSURFER_CUDA_DEVICES="0,1,2,3,4,5,6,7"
# Parkinson FastSurfer 自动 GPU 选择策略；当前按显存占用最少优先。
FASTSURFER_CUDA_SELECTION="least_memory"
# 自动 GPU 选择时最多参与挑选的 GPU 数量。
FASTSURFER_CUDA_MAX_SELECTED_DEVICES=5
# 使用 CUDA 路径时需要先 source 的 FastSurfer CUDA 环境脚本。
FASTSURFER_CUDA_ENV_SCRIPT="/data/bryang/project/CNS/tools/use_fastsurfer_cuda_env.sh"

# 如果当前配置启用了 CUDA，就把 FastSurfer 主推理设备切到 GPU。
if [[ "${FASTSURFER_USE_CUDA}" == "1" ]]; then
  # FastSurfer 主推理阶段使用的设备类型。
  FASTSURFER_DEVICE="cuda"
  # FastSurfer View Aggregation 阶段使用的设备类型。
  FASTSURFER_VIEWAGG_DEVICE="cuda"
fi
