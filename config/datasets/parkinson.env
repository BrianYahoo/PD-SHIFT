# 当前 dataset 标识，供代码识别 Parkinson 配置。
DATASET_TYPE="parkinson"
# Parkinson 原始数据根目录。
RAW_ROOT="/data/bryang/project/data/Parkinson/raw"
# Parkinson workspace 根目录。
WORKSPACE_ROOT="/data/bryang/project/data/Parkinson/workspace"
# Parkinson 的原始数据导入模式，表示从 DICOM 转换导入。
DATASET_IMPORT_MODE="parkinson_dicom"
# Parkinson 当前允许纳入 pipeline 的 subject 编号下限；用于先屏蔽后续来源不同的一批数据。
DATASET_SUBJECT_KEY_MIN=1
# Parkinson 当前允许纳入 pipeline 的 subject 编号上限；现在先限制在 1-499，暂不默认纳入 500+。
DATASET_SUBJECT_KEY_MAX=499
# Parkinson 是否在 phase0 对 T1 做重采样；当前开启。
INIT_T1_RESAMPLE_ENABLE=1
# Parkinson T1 重采样目标分辨率，单位 mm。
INIT_T1_RESAMPLE_VOXEL_SIZE=0.7
# Parkinson T1 一级优先匹配模式：优先选择非 NDC 的 0.8 mm CBCP 原生 T1。
INIT_T1_PRIORITY_1_PATTERNS="t1w_A3.22_iso0.8mm_CBCP_*;t1w*A3.22*iso0.8mm*CBCP*"
# Parkinson T1 一级优先排除模式：排除 NDC 版本，优先保留畸变校正后的非 NDC 输出。
INIT_T1_PRIORITY_1_EXCLUDE_PATTERNS="*NDC*"
# Parkinson T1 二级优先匹配模式：当一级不存在时，退回到 NDC 的 0.8 mm CBCP T1。
INIT_T1_PRIORITY_2_PATTERNS="t1w_A3.22_iso0.8mm_CBCP_NDC_*;t1w*A3.22*iso0.8mm*CBCP*NDC*"
# Parkinson T1 二级优先排除模式：当前为空。
INIT_T1_PRIORITY_2_EXCLUDE_PATTERNS=""
# Parkinson T1 三级优先匹配模式：仅在 0.8 mm CBCP 全缺失时，退回原始 sag fs 0.6 序列。
INIT_T1_PRIORITY_3_PATTERNS="t1_mx3d_sag_fs_0.6_ACS_*;t1*mx3d*sag*fs*0.6*ACS*"
# Parkinson T1 三级优先排除模式：严禁把工作站二次重切的 MPR/TRA 衍生序列导入。
INIT_T1_PRIORITY_3_EXCLUDE_PATTERNS="*MPR*;*TRA*"
# Parkinson 是否导入 T2；当前关闭，仅使用 T1。
INIT_T2_ENABLE=0
# Parkinson 从原始目录中匹配 T2 序列时使用的目录名模式列表，越靠前优先级越高。
INIT_T2_SOURCE_PATTERNS="t2_fse_tra*;t2*tra*;t2_space*;t2_cube*;t2_3d*;t2_*"
# Parkinson fMRI 是否必须从 dcm2niix 的 BIDS JSON 中读取 TR；当前强制要求。
FUNC_REQUIRE_JSON_TR=1
# Parkinson 的默认总读出时间兜底值。
DEFAULT_TOTAL_READOUT_TIME=0.05
# Parkinson phase1 默认脑提取方法，使用 FreeSurfer 7.4.1 内置 SynthStrip。
PHASE1_BRAIN_EXTRACT_METHOD="synthstrip"
# Parkinson 是否显式要求 FreeSurfer 进入 hires 路径；当前开启。
PHASE1_SURFER_HIRES=1
# Parkinson 是否启用 T2 到 T1 的刚体配准；当前关闭，仅使用 T1。
PHASE1_T2_COREG_ENABLE=0
# Parkinson 是否在 Surfer 中使用 T2；当前关闭，仅使用 T1。
PHASE1_T2_SURFER_ENABLE=0
# Parkinson 是否在 Step3 中启用 T1+T2 双通道配准；当前关闭，仅使用 T1。
PHASE1_T2_MULTICHANNEL_REG_ENABLE=0
# Parkinson 是否在 Step3 中启用皮层下 mask 约束；当前开启。
PHASE1_SUBCORTICAL_MASK_ENABLE=1
# Parkinson 是否启用 phase1 的 T1/T2/myelin 区域值与 CIFTI 输出；当前关闭，仅使用 T1。
PHASE1_TISSUE_PROFILE_ENABLE=0
# Parkinson 是否生成 32k fsLR 的 T1/T2/myelin CIFTI 与皮层 surf 图；当前关闭，仅使用 T1。
PHASE1_TISSUE_PROFILE_CIFTI_ENABLE=0
# Parkinson 是否默认在主流程中启用 EEG leadfield；当前默认关闭，按需通过配置或 issues 脚本显式打开。
PHASE1_EEG_LEADFIELD_ENABLE=0
# Parkinson Step8 默认采用 SimNIBS 内置标准 10-10 电极系统。
PHASE1_EEG_CAP_SOURCE="standard_10_10"
# Parkinson Step8 默认按 64 通道导出 EEG leadfield。
PHASE1_EEG_ELECTRODE_COUNT=64
# Parkinson 是否在 Step3 中启用 Affine 阶段；当前关闭，以保护深部结构局部锁定。
PHASE1_REG_AFFINE_ENABLE=0
# Parkinson 是否默认在 Step3 中启用原生 Lead-DBS 归一化；当前默认开启。
PHASE1_LEADDBS_NATIVE_ENABLE=1
# Parkinson 是否禁用 FreeSurfer v8 新默认流程；当前开启。
PHASE1_FREESURFER_NO_V8=1
# Parkinson 是否检查并防止误用 FreeSurfer v8 默认 synth 路径；当前开启。
PHASE1_FREESURFER_V8_GUARD=1
# Parkinson 传给 FreeSurfer `CortexLabel` 的附加参数，用于减少 cortex label 修补。
PHASE1_FREESURFER_CORTEX_LABEL_ARGS="--no-fix-ga"
# Parkinson FreeSurfer step2 可恢复错误的最大重试次数；实际最多尝试次数为该值加 1。
PHASE1_FREESURFER_RETRY_MAX=7
# Parkinson 是否默认允许 FreeSurfer topology genetic algorithm；正常开启，仅在 fallback 时自动关闭。
PHASE1_FREESURFER_FIX_WITH_GA=1
# Parkinson 默认使用哪个 FreeSurfer topology fixer；`old` 保持官方默认，`new` 只在极端 fallback 时启用。
PHASE1_FREESURFER_TOPO_FIXER_MODE="old"
# Parkinson 是否启用 FreeSurfer topology runaway watchdog；用于处理亚毫米 `-hires` 下偶发的超大拓扑缺陷。
PHASE1_FREESURFER_TOPO_RUNAWAY_ENABLE=1
# Parkinson 单个 topology defect 的 vertices 阈值，超过后认为 `mris_fix_topology` 进入异常长跑风险。
PHASE1_FREESURFER_TOPO_MAX_DEFECT_VERTICES=20000
# Parkinson 单个 topology defect 的 convex hull 阈值，超过后同样触发 topology runaway fallback。
PHASE1_FREESURFER_TOPO_MAX_DEFECT_HULL=3000
# Parkinson topology watchdog 检查 recon-all 日志的间隔秒数。
PHASE1_FREESURFER_TOPO_WATCHDOG_INTERVAL_SEC=60
# Parkinson 命中 topology runaway 后是否自动关闭 `-hires`、清空坏 subject 目录并从头重跑。
PHASE1_FREESURFER_TOPO_FALLBACK_DISABLE_HIRES=1
# Parkinson 若关闭 `-hires` 后仍命中 topology runaway，是否继续关闭 topology genetic algorithm 并重跑。
PHASE1_FREESURFER_TOPO_FALLBACK_DISABLE_FIX_GA=1
# Parkinson 若关闭 `-hires` 和 genetic algorithm 后仍命中 topology runaway，是否切换到 FreeSurfer new topology fixer 重跑。
PHASE1_FREESURFER_TOPO_FALLBACK_USE_NEW_FIXER=1
# Parkinson 若 FreeSurfer topology fallback 全部耗尽，是否在 FreeSurfer workspace 内原地切到 FastSurfer 补救。
PHASE1_FREESURFER_TOPO_FALLBACK_FASTSURFER=1
# Parkinson 传给 FastSurfer label-cortex 的附加参数，用于减少 cortex label 修补并保留 hip/amyg 处理。
PHASE1_FASTSURFER_LABEL_CORTEX_ARGS="--no-fix-ga --hip-amyg"
# Parkinson FastSurfer 固定使用的体素分辨率，单位 mm。
PHASE1_FASTSURFER_VOX_SIZE=0.7
# Parkinson FastSurfer 是否使用 CUDA；当前默认关闭，重建阶段优先使用 FreeSurfer。
FASTSURFER_USE_CUDA=0
# Parkinson FastSurfer 是否自动分配 GPU；当前默认关闭。
FASTSURFER_CUDA_AUTO_ASSIGN=0
# Parkinson 允许参与 FastSurfer 自动 GPU 分配的显卡列表。
FASTSURFER_CUDA_DEVICES="0,1,2,3,4,5,6,7"
# Parkinson FastSurfer 自动 GPU 选择策略；当前按显存占用最少优先。
FASTSURFER_CUDA_SELECTION="least_memory"
# 自动 GPU 选择时最多参与挑选的 GPU 数量。
FASTSURFER_CUDA_MAX_SELECTED_DEVICES=5
# 使用 CUDA 路径时需要先 source 的 FastSurfer CUDA 环境脚本。
FASTSURFER_CUDA_ENV_SCRIPT="/data/bryang/project/tools/use_fastsurfer_cuda_env.sh"
# Parkinson 的 DWI `eddy` 是否优先走 CUDA；当前默认关闭，因为这批数据 CPU 已能较快完成。
DWI_EDDY_USE_CUDA=0
# Parkinson 的 DWI `eddy` 是否自动分配 GPU 并用锁文件避免并发 subject 撞卡；当前默认关闭。
DWI_EDDY_CUDA_AUTO_ASSIGN=0
# Parkinson 允许参与 `eddy_cuda` 自动分配的显卡列表。
DWI_EDDY_CUDA_DEVICES="0,1,2,3,4,5,6,7"
# Parkinson 的 `eddy_cuda` GPU 选择策略；默认按显存占用最少优先。
DWI_EDDY_CUDA_SELECTION="least_memory"
# 自动 GPU 选择时最多参与挑选的 GPU 数量。
DWI_EDDY_CUDA_MAX_SELECTED_DEVICES=5
# `eddy_cuda` 的 GPU 锁文件目录。
DWI_EDDY_CUDA_LOCK_DIR="/tmp/cns_eddy_cuda_locks"
# 若当前卡池都已被占用，等待下一次重试的间隔秒数。
DWI_EDDY_CUDA_LOCK_POLL_SEC=15

# 如果当前配置启用了 CUDA，就把 FastSurfer 主推理设备切到 GPU。
if [[ "${FASTSURFER_USE_CUDA}" == "1" ]]; then
  # FastSurfer 主推理阶段使用的设备类型。
  FASTSURFER_DEVICE="cuda"
  # FastSurfer View Aggregation 阶段使用的设备类型。
  FASTSURFER_VIEWAGG_DEVICE="cuda"
fi
