DATASET_TYPE="hcp"
SURFER_TYPE="free"

RAW_ROOT="/data/bryang/project/CNS/data/HCP/raw"
WORKSPACE_ROOT="/data/bryang/project/CNS/data/HCP/workspace"
MRI_ENV_HOME="/data/bryang/project/CNS/tools/mri_env"
FSL_HOME="/data/bryang/project/CNS/tools/fsl_official"
FASTSURFER_HOME="/data/bryang/project/CNS/tools/FastSurfer"
FASTSURFER_DEVICE="cpu"
FASTSURFER_VIEWAGG_DEVICE="cpu"

SUBJECT_DIR=""
SUBJECT_ID=""

NTHREADS=8
STREAMLINES=5000000

DEFAULT_FUNC_TR=0.72
DEFAULT_TOTAL_READOUT_TIME=0.05
DUMMY_VOLUMES=10

PHASE1_BET_F=0.30
PHASE1_USE_BET=1
PHASE1_FS_XMASK_DILATIONS=2

PHASE1_REG_TRANSFORM="s"
PHASE1_LEADDBS_PRESET="effective: low variance + subcortical refinement"
WARPDRIVE_REVIEW_REQUIRED=0

FMRI_DO_TOPUP=1
FMRI_SLICE_TIMING_TR_THRESHOLD=1.0
FMRI_SMOOTH_FWHM_MM=0
FMRI_REGRESS_GS=0
FMRI_REGRESS_WM=1
FMRI_REGRESS_CSF=1
FMRI_REGRESS_HM=1
FMRI_HM_MODEL=24
FMRI_DETREND_ORDER=1
FMRI_LOW_CUT_HZ=0.01
FMRI_HIGH_CUT_HZ=0.10
FMRI_ENABLE_SCRUBBING=0
FMRI_FD_THRESHOLD=0.5
FMRI_SCRUB_BEFORE=0
FMRI_SCRUB_AFTER=0

DWI_LMAX=8
DWI_ENABLE_REVERSE_PE=1
TRACT_MIN_LENGTH=4
TRACT_MAX_LENGTH=200
TRACT_MAX_ANGLE=45
CONNECTOME_ASSIGNMENT_RADIAL_SEARCH=2
CONNECTOME_SCALE_INVNODEVOL=1
DWI_5TT_FIX_HYBRID_SUBCGM=1

DISTAL_ATLAS_DIR="/data/bryang/project/CNS/tools/leaddbs/templates/space/MNI152NLin2009bAsym/atlases/DISTAL Minimal (Ewert 2017)"
SN_ATLAS_DIR="/data/bryang/project/CNS/tools/leaddbs/templates/space/MNI152NLin2009bAsym/atlases/ATAG_Nonlinear (Keuken 2014)"
MNI_T1="/data/bryang/project/CNS/tools/leaddbs/templates/space/MNI152NLin2009bAsym/t1.nii"
MNI_BRAINMASK="/data/bryang/project/CNS/tools/leaddbs/templates/space/MNI152NLin2009bAsym/brainmask.nii.gz"

FC_REFERENCE_ROOT="/data/bryang/project/CNS/ref/HCP"
SC_REFERENCE_ROOT="/data/bryang/project/CNS/ref/The-Virtual-Parkinsonian-Patient-main"
