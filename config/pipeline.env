# 默认数据集类型，作为未显式传入 `--dataset` 时的兜底值。
DATASET_TYPE="hcp"
# 默认 Surfer 引擎类型，作为未显式传入 `--surfer` 时的兜底值。
SURFER_TYPE="free"

# 默认原始数据根目录，实际运行时可被 dataset config 覆盖。
RAW_ROOT="/data/bryang/project/CNS/data/HCP/raw"
# 默认 workspace 根目录，实际运行时可被 dataset config 覆盖。
WORKSPACE_ROOT="/data/bryang/project/CNS/data/HCP/workspace"
# 统一 MRI 工具环境目录，用于加载 conda/FSL/FreeSurfer/ANTs 等环境。
MRI_ENV_HOME="/data/bryang/project/CNS/tools/mri_env"
# FSL 安装根目录。
FSL_HOME="/data/bryang/project/CNS/tools/fsl_official"
# FastSurfer 安装根目录。
FASTSURFER_HOME="/data/bryang/project/CNS/tools/FastSurfer"
# FastSurfer 默认主推理设备，dataset config 可覆盖为 GPU。
FASTSURFER_DEVICE="cpu"
# FastSurfer View Aggregation 默认设备，dataset config 可覆盖为 GPU。
FASTSURFER_VIEWAGG_DEVICE="cpu"

# 允许外部显式注入 subject 原始目录；为空时由 dataset/raw 自动解析。
SUBJECT_DIR=""
# 允许外部显式注入标准化后的 subject_id；通常由代码自动生成。
SUBJECT_ID=""

# 默认 CPU 线程数。
NTHREADS=8
# DWI tractography 默认追踪纤维条数。
STREAMLINES=5000000

# fMRI 默认 TR 兜底值，仅在允许 fallback 的数据集上使用。
DEFAULT_FUNC_TR=0.72
# topup / applytopup 默认总读出时间兜底值。
DEFAULT_TOTAL_READOUT_TIME=0.05
# fMRI 预处理时默认丢弃的起始 dummy volumes 数量。
DUMMY_VOLUMES=10

# 是否在 phase0 导入 T2。
INIT_T2_ENABLE=0
# Parkinson 等 DICOM 数据集中，用于匹配 T2 序列目录名的模式列表。
INIT_T2_SOURCE_PATTERNS=""
# HCP 数据集中，用于查找 T2 目录的候选目录名。
INIT_T2_HCP_DIR_CANDIDATES="T2w_SPC1;T2w_SPC2"
# HCP 数据集中，用于在候选目录里匹配 T2 NIfTI 文件名的模式。
INIT_T2_HCP_FILE_PATTERNS="*T2w*.nii.gz"

# FSL BET 的默认脑提取阈值参数。
PHASE1_BET_F=0.30
# 是否允许走 BET 路径；为 0 时会强制禁用 BET。
PHASE1_USE_BET=1
# 生成 FreeSurfer 专用宽松 xmask 时的默认膨胀次数。
PHASE1_FS_XMASK_DILATIONS=2
# 是否启用 T2 到 T1 的刚体配准；默认跟随 T2 导入开关。
PHASE1_T2_COREG_ENABLE="${INIT_T2_ENABLE}"
# 是否在 Surfer 重建阶段把 T2 喂给 FreeSurfer/FastSurfer；默认跟随 T2 刚体配准开关。
PHASE1_T2_SURFER_ENABLE="${PHASE1_T2_COREG_ENABLE}"
# 是否在 Step3 深部配准中启用 T1+T2 双通道；默认跟随 T2 刚体配准开关。
PHASE1_T2_MULTICHANNEL_REG_ENABLE="${PHASE1_T2_COREG_ENABLE}"
# 是否在 Step3 深部配准中启用皮层下约束 mask。
PHASE1_SUBCORTICAL_MASK_ENABLE=0
# 是否启用 phase1 的 T1/T2/myelin 区域值与 CIFTI 输出步骤；默认跟随 T2 刚体配准开关。
PHASE1_TISSUE_PROFILE_ENABLE="${PHASE1_T2_COREG_ENABLE}"
# 是否额外生成 32k fsLR 的 T1/T2/myelin CIFTI 与皮层 surf 图；默认跟随 tissue profile 总开关。
PHASE1_TISSUE_PROFILE_CIFTI_ENABLE="${PHASE1_TISSUE_PROFILE_ENABLE}"
# T1/T2/myelin CIFTI 输出的 fsLR 低分辨率网格大小，单位 k。
PHASE1_TISSUE_PROFILE_FSLR_MESH_K=32
# 生成 fsLR 配准球面时使用的高分辨率网格大小，单位 k。
PHASE1_TISSUE_PROFILE_HIGHRES_MESH_K=164
# phase1 的 surf 图使用哪个 Python 渲染环境；可选 `osmesa` 或 `mri_env`。
PHASE1_SURFACE_PLOT_ENV="osmesa"
# 当 surf 图使用 `mri_env` 时，默认调用的 Python 路径；留空表示直接复用当前 `mri_env` 的 `PYTHON_BIN`。
PHASE1_SURFACE_PLOT_MRI_PYTHON=""
# 当 surf 图使用 `osmesa` 时，调用的独立 Python 路径。
PHASE1_SURFACE_PLOT_OSMESA_PYTHON="/data/bryang/project/CNS/tools/surfplot_osmesa_env/bin/python"

# Step3 里 ANTs 配准使用的 transform 预设标签。
PHASE1_REG_TRANSFORM="s"
# Step3 是否在 Rigid 和 SyN 之间加入 Affine 阶段。
PHASE1_REG_AFFINE_ENABLE=1
# 记录当前 Lead-DBS 风格深部配准策略说明，写入 manifest 便于追踪。
PHASE1_LEADDBS_PRESET="effective: low variance + subcortical refinement"
# 是否要求 Step4 手工 WarpDrive 复核。
WARPDRIVE_REVIEW_REQUIRED=0

# fMRI 是否在满足条件时执行 topup。
FMRI_DO_TOPUP=1
# 只有当 TR 高于该阈值时，才执行 slice timing correction。
FMRI_SLICE_TIMING_TR_THRESHOLD=1.0
# fMRI 空间平滑的 FWHM，单位 mm；为 0 表示跳过。
FMRI_SMOOTH_FWHM_MM=0
# 是否回归 global signal。
FMRI_REGRESS_GS=0
# 是否回归白质信号。
FMRI_REGRESS_WM=1
# 是否回归脑脊液信号。
FMRI_REGRESS_CSF=1
# 是否回归头动参数。
FMRI_REGRESS_HM=1
# 头动回归模型阶数，当前默认 24 参数模型。
FMRI_HM_MODEL=24
# 时间去趋势的多项式阶数。
FMRI_DETREND_ORDER=1
# fMRI 带通滤波的低截止频率，单位 Hz。
FMRI_LOW_CUT_HZ=0.01
# fMRI 带通滤波的高截止频率，单位 Hz。
FMRI_HIGH_CUT_HZ=0.10
# 是否真正执行 scrubbing 删帧；为 0 时只做标记。
FMRI_ENABLE_SCRUBBING=0
# 触发 scrub 标记的 FD 阈值。
FMRI_FD_THRESHOLD=0.5
# scrub 时在坏帧之前额外连带去除的帧数。
FMRI_SCRUB_BEFORE=0
# scrub 时在坏帧之后额外连带去除的帧数。
FMRI_SCRUB_AFTER=0

# DWI FOD 建模使用的最大球谐阶数。
DWI_LMAX=8
# 是否启用 reverse PE DWI 参与 topup/eddy。
DWI_ENABLE_REVERSE_PE=1
# tractography 允许的最短纤维长度，单位 mm。
TRACT_MIN_LENGTH=4
# tractography 允许的最长纤维长度，单位 mm。
TRACT_MAX_LENGTH=200
# tractography 每步允许的最大转角，单位 degree。
TRACT_MAX_ANGLE=45
# 主流程 connectome 的 assignment radial search 半径。
CONNECTOME_ASSIGNMENT_RADIAL_SEARCH=2
# 是否修补 5TT 中 hybrid atlas 深部 subcortical GM 通道。
DWI_5TT_FIX_HYBRID_SUBCGM=1

# Lead-DBS DISTAL atlas 所在目录。
DISTAL_ATLAS_DIR="/data/bryang/project/CNS/tools/leaddbs/templates/space/MNI152NLin2009bAsym/atlases/DISTAL%20Minimal%20%28Ewert%202017%29"
# Lead-DBS 黑质 atlas 所在目录。
SN_ATLAS_DIR="/data/bryang/project/CNS/tools/leaddbs/templates/space/MNI152NLin2009bAsym/atlases/ATAG_Nonlinear%20%28Keuken%202014%29"
# Step3 使用的 MNI T1 模板路径。
MNI_T1="/data/bryang/project/CNS/tools/leaddbs/templates/space/MNI152NLin2009bAsym/t1.nii"
# Step3 双通道配准时使用的 MNI T2 模板路径。
MNI_T2="/data/bryang/project/CNS/tools/leaddbs/templates/space/MNI152NLin2009bAsym/t2.nii"
# Step3 准备 MNI brain 时使用的脑掩膜路径。
MNI_BRAINMASK="/data/bryang/project/CNS/tools/leaddbs/templates/space/MNI152NLin2009bAsym/brainmask.nii.gz"
# Step3 深部约束配准时使用的 MNI 皮层下 mask 路径。
MNI_SUBCORTICAL_MASK="/data/bryang/project/CNS/tools/leaddbs/templates/space/MNI152NLin2009bAsym/subcortical/thirdstepmask.nii"

# FC 参考数据根目录，用于 phase4 与 HCP 参考进行对比。
FC_REFERENCE_ROOT="/data/bryang/project/CNS/ref/HCP"
# SC / TVP 参考数据根目录，用于 phase4 导出和参考对比。
SC_REFERENCE_ROOT="/data/bryang/project/CNS/ref/The-Virtual-Parkinsonian-Patient-main"
